{
  "name": "energy-saving-demo",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo -p 3001",
    "dev:warm": "powershell -NoProfile -Command \"while($true){try{[void](Invoke-WebRequest -UseBasicParsing http://localhost:3001 -TimeoutSec 2); break}catch{Start-Sleep -Milliseconds 350}}\"",
    "dev:fast": "concurrently --kill-others-on-fail -n DEV,WARM -c cyan,magenta \"npm run dev\" \"npm run dev:warm\"",
    "build": "cross-env NODE_ENV=production next build",
    "start": "next start",
    "export": "next build && next export"
  },
  "dependencies": {
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.19.1",
    "@types/three": "^0.183.1",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "recharts": "^2.12.7",
    "three": "^0.183.1"
  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.4",
    "typescript": "5.4.5"
  }
}
